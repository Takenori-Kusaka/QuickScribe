{
  "name": "quickscribe",
  "version": "0.0.1",
  "description": "思考整理・自己理解のためのローカル完結ボイスジャーナル",
  "license": "MIT",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "preview": "vite preview",
    "check": "svelte-check --tsconfig ./tsconfig.json",
    "lint": "eslint .",
    "lint:css": "stylelint \"src/**/*.{css,svelte}\"",
    "lint:text": "textlint \"books/**/*.md\"",
    "structurizr": "node scripts/render-structurizr.mjs",
    "structurizr:check": "node scripts/render-structurizr.mjs --check",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "docs:check": "npx -y typedoc@0.28.5",
    "test": "vitest run",
    "coverage": "vitest run --coverage",
    "e2e": "wdio run e2e/wdio.conf.cjs",
    "screenshots": "playwright test",
    "demo:gif": "node scripts/make-demo-gif.mjs",
    "licenses": "node scripts/generate-frontend-notices.cjs",
    "metrics": "node scripts/release-metrics.mjs",
    "icons": "tauri icon assets/brand/icon-source.png",
    "tauri": "tauri"
  },
  "dependencies": {
    "@tauri-apps/api": "^2.11.1",
    "@tauri-apps/plugin-autostart": "^2.5.1",
    "@tauri-apps/plugin-dialog": "^2.2.0",
    "@tauri-apps/plugin-global-shortcut": "^2.2.0",
    "@tauri-apps/plugin-notification": "^2.2.0",
    "@tauri-apps/plugin-process": "^2.2.0",
    "@tauri-apps/plugin-updater": "^2.3.0",
    "svelte-i18n": "^4.0.1"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@playwright/test": "^1.61.1",
    "@sveltejs/vite-plugin-svelte": "^7.1.2",
    "@tauri-apps/cli": "^2.11.4",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/svelte": "^5.4.2",
    "@vitest/coverage-v8": "^4.1.9",
    "@wdio/cli": "^9.29.1",
    "@wdio/local-runner": "^9.29.1",
    "@wdio/mocha-framework": "^9.29.1",
    "@wdio/spec-reporter": "^9.29.1",
    "eslint": "^10.6.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-svelte": "^3.20.0",
    "globals": "^17.7.0",
    "jsdom": "^29.1.1",
    "license-checker-rseidelsohn": "^5.0.1",
    "pngjs": "^7.0.0",
    "postcss-html": "^1.8.1",
    "prettier": "^3.9.4",
    "prettier-plugin-svelte": "^4.1.1",
    "stylelint": "^17.14.0",
    "svelte": "^5.56.4",
    "svelte-check": "^4.7.1",
    "svelte-eslint-parser": "^1.8.0",
    "textlint": "^15.7.1",
    "textlint-filter-rule-comments": "^1.3.0",
    "textlint-rule-preset-ja-technical-writing": "^12.0.2",
    "tslib": "^2.8.0",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.63.0",
    "vite": "^8.1.3",
    "vitest": "^4.1.9"
  }
}
