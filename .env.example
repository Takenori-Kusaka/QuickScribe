# QuickScribe — 環境変数テンプレート
# このファイルをコピーして `.env` を作成し、値を記入してください。
# `.env` は .gitignore 済みでコミットされません。秘密情報は必ず .env に置くこと。

# Gemini API キー（ブランド/アイコン等の画像生成、将来の整形プラグイン検証に使用）
# 取得: https://aistudio.google.com/apikey
GEMINI_API_KEY=

# 将来のSTT/LLMプラグイン用（任意・未使用なら空で可）
# GROQ_API_KEY=
# OPENAI_API_KEY=
# ANTHROPIC_API_KEY=
