{
  "$schema": "https://schema.tauri.app/config/2",
  "bundle": {
    "resources": {
      "THIRD-PARTY-NOTICES.txt": "./",
      "cuda-dlls/*": "./"
    },
    "createUpdaterArtifacts": false,
    "windows": {
      "nsis": {
        "installerHooks": "./nsis-hooks-cuda.nsh"
      }
    }
  },
  "plugins": {
    "updater": {
      "endpoints": [
        "https://github.com/Takenori-Kusaka/QuickScribe/releases/latest/download/latest-cuda.json"
      ]
    }
  }
}
